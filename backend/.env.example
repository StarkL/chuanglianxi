PORT=5000
NODE_ENV=production
DATABASE_URL="file:./data.db"
CORS_ORIGIN=http://your-domain.com
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
JWT_SECRET=dev_jwt_secret_must_be_at_least_32_characters_long

# OCR configuration (Baidu is optional, Qwen visual LLM is used as default)
BAIDU_OCR_APP_ID=your_baidu_ocr_app_id
BAIDU_OCR_API_KEY=your_baidu_ocr_api_key
BAIDU_OCR_SECRET_KEY=your_baidu_ocr_secret_key
QWEN_API_KEY=your_qwen_api_key

# WeChat template notification settings (Optional)
WECHAT_SUBSCRIPTION_TEMPLATE_ID_RELATIONSHIP=your_relationship_template_id
WECHAT_SUBSCRIPTION_TEMPLATE_ID_BIRTHDAY=your_birthday_template_id
WECHAT_SUBSCRIPTION_TEMPLATE_ID_CUSTOM=your_custom_template_id
